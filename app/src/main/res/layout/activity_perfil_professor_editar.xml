<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Perfil_Professor_Editar">

    <!-- Toolbar Superior (original) -->
    <LinearLayout
        android:id="@+id/toolbarAluno"
        android:layout_width="411dp"
        android:layout_height="60dp"
        android:background="#E1E1E1"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnVoltar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Voltar"
            android:padding="10dp"
            app:srcCompat="@drawable/icone_voltar" />

        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="UniGym"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnProfileTopBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/profile_image_button"
            android:padding="4dp"
            app:srcCompat="@drawable/profile_picture" />
    </LinearLayout>

    <!-- Foto de Perfil (original) -->
    <ImageView
        android:id="@+id/imgPerfil"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="fitCenter"
        android:src="@drawable/profile_picture"
        app:layout_constraintTop_toBottomOf="@id/toolbarAluno"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- Botão Editar Foto (original) -->
    <ImageButton
        android:id="@+id/btnEditarImagem"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Editar imagem"
        android:padding="12dp"
        app:srcCompat="@drawable/icone_edit"
        app:layout_constraintTop_toBottomOf="@id/imgPerfil"
        app:layout_constraintStart_toStartOf="@id/imgPerfil"
        app:layout_constraintEnd_toEndOf="@id/imgPerfil"
        android:layout_marginTop="8dp"/>

    <!-- Campos do Formulário (ORIGINAL RESTAURADO) -->
    <LinearLayout
        android:id="@+id/camposLayout"
        android:layout_width="411dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/btnEditarImagem"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp">

        <!-- Campo: Nome -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editNome"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@color/mediumGray"
                android:hint="Nome"
                android:padding="10dp" />

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar nome"
                android:padding="12dp"
                app:srcCompat="@drawable/icone_edit" />
        </LinearLayout>

        <!-- Campo: Email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editEmail"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@color/mediumGray"
                android:hint="Email"
                android:padding="10dp" />

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar email"
                android:padding="12dp"
                app:srcCompat="@drawable/icone_edit" />
        </LinearLayout>

        <!-- Campo: Data de nascimento -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editDataNascimento"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@color/mediumGray"
                android:hint="Data de nascimento"
                android:padding="10dp" />

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar data"
                android:padding="12dp"
                app:srcCompat="@drawable/icone_edit" />
        </LinearLayout>

        <!-- Campo: Sexo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editSexo"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@color/mediumGray"
                android:hint="Sexo"
                android:padding="10dp" />

            <ImageButton
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar sexo"
                android:padding="12dp"
                app:srcCompat="@drawable/icone_edit" />
        </LinearLayout>
    </LinearLayout>

    <!-- Botão Confirmar (original) -->
    <Button
        android:id="@+id/btnConfirmar"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:background="@color/mediumGray"
        android:minWidth="200dp"
        android:text="Confirmar novos dados"
        app:layout_constraintTop_toBottomOf="@id/camposLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- Toolbar Inferior (original) -->
    <LinearLayout
        android:id="@+id/toolbarProfessor"
        android:layout_width="411dp"
        android:layout_height="60dp"
        android:background="#E1E1E1"
        android:gravity="bottom"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:backgroundTint="#00FFFFFF"
            android:contentDescription="@string/home_image_button"
            app:srcCompat="@drawable/house_picture" />

        <ImageButton
            android:id="@+id/btnAdd"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:backgroundTint="#00FFFFFF"
            android:contentDescription="@string/add_image_button"
            app:srcCompat="@drawable/add_picture" />

        <ImageButton
            android:id="@+id/btnProfile"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:backgroundTint="#00FFFFFF"
            android:contentDescription="@string/profile_image_button"
            app:srcCompat="@drawable/profile_picture" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
